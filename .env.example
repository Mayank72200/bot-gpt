# Copy this file to .env and fill in your values
# All settings use the BOTGPT_ prefix

BOTGPT_MISTRAL_API_KEY=your-mistral-api-key-here
BOTGPT_MISTRAL_BASE_URL=https://api.mistral.ai/v1
BOTGPT_MISTRAL_CHAT_MODEL=mistral-small-latest
BOTGPT_MISTRAL_EMBEDDING_MODEL=mistral-embed

BOTGPT_DATABASE_URL=sqlite:///./bot_gpt.db
BOTGPT_MAX_HISTORY_MESSAGES=10

HF_TOKEN=your-huggingface-token-here
